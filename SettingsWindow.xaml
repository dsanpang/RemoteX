<Window x:Class="RemoteX.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="540"
        Height="700"
        MinHeight="420"
        MaxHeight="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E2E"
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- 分节标题 -->
        <Style x:Key="SectionTitle" TargetType="DockPanel">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- 设置行 -->
        <Style x:Key="SettingRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- 主标签 -->
        <Style x:Key="RL" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#CDD6F4"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 辅助说明 -->
        <Style x:Key="RH" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize"   Value="10.5"/>
            <Setter Property="Margin"     Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- 数字输入框 -->
        <Style x:Key="NI" TargetType="TextBox">
            <Setter Property="Background"               Value="#313244"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#45475A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="CaretBrush"               Value="#89B4FA"/>
            <Setter Property="SelectionBrush"         Value="#89B4FA"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Width"                    Value="88"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="TextAlignment"            Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment"      Value="Right"/>
            <Setter Property="VerticalAlignment"        Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#89B4FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 区块容器 -->
        <Style x:Key="SectionBlock" TargetType="Border">
            <Setter Property="Background"   Value="#252536"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding"      Value="18,14"/>
            <Setter Property="Margin"       Value="0,0,0,18"/>
        </Style>

        <!-- 通用输入框（与主界面一致高度） -->
        <Style x:Key="TI" TargetType="TextBox">
            <Setter Property="Background"               Value="#313244"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#45475A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="CaretBrush"               Value="#89B4FA"/>
            <Setter Property="SelectionBrush"           Value="#89B4FA"/>
            <Setter Property="Padding"                   Value="8,0"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#89B4FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0" Margin="0"
                  VerticalAlignment="Stretch">
    <StackPanel Margin="32,24,32,32">

        <!-- ── 健康检测 ── -->
        <Border Style="{StaticResource SectionBlock}">
            <StackPanel>
                <DockPanel Style="{StaticResource SectionTitle}">
                    <Border DockPanel.Dock="Left" Width="3" CornerRadius="2" Background="#A6E3A1" Margin="0,1,10,1"/>
                    <TextBlock Text="健康检测" Foreground="#A6E3A1" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>
                <Grid Style="{StaticResource SettingRow}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="检测超时（毫秒）" Style="{StaticResource RL}"/>
                        <TextBlock Text="TCP 端口连通性探测的最大等待时间" Style="{StaticResource RH}"/>
                    </StackPanel>
                    <TextBox x:Name="HealthTimeoutBox" Grid.Column="1" Style="{StaticResource NI}"/>
                </Grid>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="并发检测数" Style="{StaticResource RL}"/>
                        <TextBlock Text="批量检测时同时进行的最大并发数（1~64）" Style="{StaticResource RH}"/>
                    </StackPanel>
                    <TextBox x:Name="HealthConcurrencyBox" Grid.Column="1" Style="{StaticResource NI}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── RDP 连接 ── -->
        <Border Style="{StaticResource SectionBlock}">
            <StackPanel>
                <DockPanel Style="{StaticResource SectionTitle}">
                    <Border DockPanel.Dock="Left" Width="3" CornerRadius="2" Background="#89B4FA" Margin="0,1,10,1"/>
                    <TextBlock Text="RDP 连接" Foreground="#89B4FA" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>
                <Grid Style="{StaticResource SettingRow}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="连接超时（毫秒）" Style="{StaticResource RL}"/>
                        <TextBlock Text="RDP 握手未响应时的最长等待时间" Style="{StaticResource RH}"/>
                    </StackPanel>
                    <TextBox x:Name="ConnectTimeoutBox" Grid.Column="1" Style="{StaticResource NI}"/>
                </Grid>
                <Grid Style="{StaticResource SettingRow}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="默认端口" Style="{StaticResource RL}"/>
                        <TextBlock Text="新增服务器时的端口号预填值" Style="{StaticResource RH}"/>
                    </StackPanel>
                    <TextBox x:Name="DefaultPortBox" Grid.Column="1" Style="{StaticResource NI}"/>
                </Grid>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="RDP 证书验证" Style="{StaticResource RL}"/>
                        <TextBlock Text="0=静默接受，2=无效证书时警告并询问" Style="{StaticResource RH}"/>
                    </StackPanel>
                    <TextBox x:Name="RdpAuthLevelBox" Grid.Column="1" Style="{StaticResource NI}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── SOCKS 代理（多机房跳板机）── -->
        <Border Style="{StaticResource SectionBlock}">
            <StackPanel>
                <DockPanel Style="{StaticResource SectionTitle}">
                    <Border DockPanel.Dock="Left" Width="3" CornerRadius="2" Background="#F9E2AF" Margin="0,1,10,1"/>
                    <TextBlock Text="SOCKS 代理（多机房跳板机）" Foreground="#F9E2AF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock Text="每机房一个代理；在「编辑服务器」中选择该服务器通过哪个代理连接。" Style="{StaticResource RH}" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="SocksProxyListBox" Grid.Column="0" MinHeight="88" MaxHeight="140"
                             Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1"
                             FontSize="12" SelectionChanged="SocksProxyListBox_SelectionChanged"
                             DisplayMemberPath="Name" Padding="6,4"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,0,0">
                        <Button x:Name="SocksAddBtn" Content="添加" Height="32" Margin="0,0,0,6" Style="{StaticResource DlgSecondaryBtn}" Click="SocksAdd_Click"/>
                        <Button x:Name="SocksSaveBtn" Content="更新" Height="32" Margin="0,0,0,6" Style="{StaticResource DlgSecondaryBtn}" Click="SocksSave_Click"/>
                        <Button x:Name="SocksDelBtn"  Content="删除" Height="32" Style="{StaticResource DlgSecondaryBtn}" Click="SocksDel_Click"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="选中一项后编辑下方并点击「更新」" Style="{StaticResource RH}" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="名称" Style="{StaticResource RL}" VerticalAlignment="Center"/>
                    <TextBox x:Name="SocksNameBox" Grid.Column="1" Style="{StaticResource TI}"/>
                    <TextBlock Grid.Column="3" Text="主机" Style="{StaticResource RL}" VerticalAlignment="Center"/>
                    <TextBox x:Name="SocksHostBox" Grid.Column="4" Style="{StaticResource TI}"/>
                    <TextBlock Grid.Column="6" Text="端口" Style="{StaticResource RL}" VerticalAlignment="Center"/>
                    <TextBox x:Name="SocksPortBox" Grid.Column="7" Style="{StaticResource NI}" Width="72" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="56"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="用户名" Style="{StaticResource RL}" VerticalAlignment="Center"/>
                    <TextBox x:Name="SocksUsernameBox" Grid.Column="1" Style="{StaticResource TI}"/>
                    <TextBlock Grid.Column="3" Text="密码" Style="{StaticResource RL}" VerticalAlignment="Center"/>
                    <PasswordBox x:Name="SocksPasswordBox" Grid.Column="4" Height="34" Padding="8,0"
                                 Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" BorderThickness="1" FontSize="13"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── 历史记录 ── -->
        <Border Style="{StaticResource SectionBlock}">
            <StackPanel>
                <DockPanel Style="{StaticResource SectionTitle}">
                    <Border DockPanel.Dock="Left" Width="3" CornerRadius="2" Background="#CBA6F7" Margin="0,1,10,1"/>
                    <TextBlock Text="历史记录" Foreground="#CBA6F7" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="最近连接记录数" Style="{StaticResource RL}"/>
                        <TextBlock Text="侧边栏保留的最近连接历史条数（1~50）" Style="{StaticResource RH}"/>
                    </StackPanel>
                    <TextBox x:Name="MaxRecentBox" Grid.Column="1" Style="{StaticResource NI}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── 按钮栏 ── -->
        <Border Height="1" Background="#313244" Margin="0,8,0,16"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
            <Button Content="取 消" Width="96" Height="34" Margin="0,0,10,0"
                    Style="{StaticResource DlgSecondaryBtn}" Click="CancelButton_Click" IsCancel="True"/>
            <Button Content="确 定" Width="96" Height="34"
                    Style="{StaticResource DlgPrimaryBtn}" Click="OkButton_Click" IsDefault="True"/>
        </StackPanel>

    </StackPanel>
    </ScrollViewer>
</Window>
