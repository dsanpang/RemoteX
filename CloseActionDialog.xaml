<Window x:Class="RemoteX.CloseActionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关闭"
        Width="360"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        ShowInTaskbar="False">

    <StackPanel Margin="28,24,28,24">

        <!-- 图标 + 标题 -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="38" Height="38"
                    Background="#89B4FA"
                    CornerRadius="10"
                    Margin="0,0,12,0">
                <TextBlock Text="R"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#1E1E2E"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="关闭 RemoteX"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#CDD6F4"/>
                <TextBlock Text="请选择关闭窗口时的操作"
                           FontSize="11"
                           Foreground="#6C7086"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- 分割线 -->
        <Border Height="1" Background="#313244" Margin="0,0,0,18"/>

        <!-- 选项：最小化到托盘 -->
        <Border x:Name="TrayOptionBd"
                Background="#252535"
                BorderBrush="#45475A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,12"
                Margin="0,0,0,10"
                Cursor="Hand"
                MouseLeftButtonUp="TrayOption_Click">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x229F;" FontSize="20"
                           Foreground="#89B4FA"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="最小化到系统托盘"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#CDD6F4"/>
                    <TextBlock Text="程序继续在后台运行，双击托盘图标可重新打开"
                               FontSize="11"
                               Foreground="#6C7086"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 选项：退出程序 -->
        <Border x:Name="ExitOptionBd"
                Background="#252535"
                BorderBrush="#45475A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,12"
                Margin="0,0,0,16"
                Cursor="Hand"
                MouseLeftButtonUp="ExitOption_Click">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#x2715;" FontSize="18"
                           Foreground="#F38BA8"
                           VerticalAlignment="Center"
                           Margin="0,0,13,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="退出程序"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#CDD6F4"/>
                    <TextBlock Text="关闭所有连接并完全退出 RemoteX"
                               FontSize="11"
                               Foreground="#6C7086"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 记住选择 -->
        <CheckBox x:Name="RememberCheck"
                  Content="记住我的选择，下次不再询问"
                  Foreground="#6C7086"
                  FontSize="11"
                  Margin="2,0,0,0">
            <CheckBox.Resources>
                <Style TargetType="CheckBox">
                    <Setter Property="Foreground" Value="#6C7086"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="CheckBox">
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="Chk"
                                            Width="15" Height="15"
                                            Background="Transparent"
                                            BorderBrush="#45475A"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Margin="0,0,7,0">
                                        <TextBlock x:Name="ChkMark"
                                                   Text="&#x2713;"
                                                   FontSize="10"
                                                   Foreground="#89B4FA"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </Border>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </StackPanel>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Chk"    Property="Background"   Value="#1A3254"/>
                                        <Setter TargetName="Chk"    Property="BorderBrush"  Value="#89B4FA"/>
                                        <Setter TargetName="ChkMark" Property="Visibility"  Value="Visible"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </CheckBox.Resources>
        </CheckBox>

    </StackPanel>
</Window>
