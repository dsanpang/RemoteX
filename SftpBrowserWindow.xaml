<Window x:Class="RemoteX.SftpBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Window.Resources>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6C7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TreeView style -->
        <Style TargetType="TreeView">
            <Setter Property="Background"   Value="#181825"/>
            <Setter Property="Foreground"   Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground"  Value="#CDD6F4"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Padding"     Value="4,3"/>
            <Setter Property="Cursor"      Value="Hand"/>
        </Style>

        <!-- ListView style -->
        <Style TargetType="ListView">
            <Setter Property="Background"      Value="#1E1E2E"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Foreground"  Value="#CDD6F4"/>
            <Setter Property="Padding"     Value="4,3"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A3254"/>
                    <Setter Property="Foreground" Value="#89B4FA"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#313244"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"   Value="#11111B"/>
            <Setter Property="Foreground"   Value="#A6ADC8"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="BorderBrush"  Value="#313244"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"      Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Scrollbar -->
        <Style x:Key="FlatScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#45475A" CornerRadius="3" Margin="2,1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>   <!-- Toolbar -->
            <RowDefinition Height="32"/>   <!-- Path bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0" Background="#11111B"
                BorderBrush="#313244" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <Button x:Name="BtnUpload"   Content="上传"     Style="{StaticResource ToolBtn}" Click="BtnUpload_Click"/>
                <Button x:Name="BtnDownload" Content="下载"     Style="{StaticResource ToolBtn}" Click="BtnDownload_Click"/>
                <Button x:Name="BtnMkDir"    Content="新建文件夹" Style="{StaticResource ToolBtn}" Click="BtnMkDir_Click"/>
                <Button x:Name="BtnRename"   Content="重命名"   Style="{StaticResource ToolBtn}" Click="BtnRename_Click"/>
                <Button x:Name="BtnDelete"   Content="删除"     Style="{StaticResource ToolBtn}" Foreground="#F38BA8" Click="BtnDelete_Click"/>
                <Separator Width="1" Background="#45475A" Margin="6,8"/>
                <Button x:Name="BtnRefresh"  Content="刷新"     Style="{StaticResource ToolBtn}" Click="BtnRefresh_Click"/>
            </StackPanel>
        </Border>

        <!-- ── Path bar ── -->
        <Border Grid.Row="1" Background="#181825"
                BorderBrush="#313244" BorderThickness="0,0,0,1"
                Padding="12,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="路径：" Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="PathBar" Text="/" Foreground="#89B4FA" FontSize="12"
                           FontFamily="Consolas,Courier New,monospace"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- ── Content area ── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="120" MaxWidth="400"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Directory tree -->
            <Border Grid.Column="0" Background="#181825" BorderBrush="#313244" BorderThickness="0,0,1,0">
                <TreeView x:Name="DirTree" SelectedItemChanged="DirTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Foreground" Value="#CDD6F4"/>
                            <Setter Property="FontSize"   Value="12"/>
                            <Setter Property="Padding"    Value="2,3"/>
                            <Setter Property="Cursor"     Value="Hand"/>
                            <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="#313244" Cursor="SizeWE"/>

            <!-- File list -->
            <ListView x:Name="FileList" Grid.Column="2"
                      SelectionMode="Extended"
                      MouseDoubleClick="FileList_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="名称" Width="280"
                                        DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="大小" Width="90"
                                        DisplayMemberBinding="{Binding SizeDisplay}"/>
                        <GridViewColumn Header="修改时间" Width="150"
                                        DisplayMemberBinding="{Binding ModifyTime}"/>
                        <GridViewColumn Header="权限" Width="100"
                                        DisplayMemberBinding="{Binding Permissions}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- ── Status / Progress bar ── -->
        <Border Grid.Row="3" Background="#11111B" BorderBrush="#313244" BorderThickness="0,1,0,0" Padding="12,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ProgressBar x:Name="TransferProgress" Grid.Row="0"
                             Height="4" Margin="0,0,0,4"
                             Foreground="#89B4FA" Background="#313244"
                             BorderThickness="0"
                             Visibility="Collapsed"/>
                <TextBlock x:Name="TransferStatus" Grid.Row="1"
                           Foreground="#A6ADC8" FontSize="11"
                           Text="就绪"/>
            </Grid>
        </Border>
    </Grid>
</Window>
