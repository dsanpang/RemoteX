<Window x:Class="RemoteX.ServerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480"
        SizeToContent="Height"
        MaxHeight="740"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- 表单标签 -->
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground"         Value="#A6ADC8"/>
            <Setter Property="FontSize"           Value="12"/>
            <Setter Property="VerticalAlignment"  Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin"             Value="0,0,14,0"/>
        </Style>

        <!-- 单行输入框 -->
        <Style x:Key="FI" TargetType="TextBox">
            <Setter Property="Background"               Value="#313244"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#45475A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="CaretBrush"               Value="#89B4FA"/>
            <Setter Property="SelectionBrush"           Value="#89B4FA"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <EventSetter Event="GotKeyboardFocus" Handler="Input_GotFocus"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#89B4FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 密码框：通过 ControlTemplate 强制让 PART_ContentHost 垂直居中 -->
        <Style x:Key="FP" TargetType="PasswordBox">
            <Setter Property="Background"               Value="#313244"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#45475A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="CaretBrush"               Value="#89B4FA"/>
            <Setter Property="SelectionBrush"           Value="#89B4FA"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <!-- Padding 由 PasswordBox 内部渲染引擎自动应用，模板不再重复绑定 -->
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Hidden"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉框（与输入框风格统一） -->
        <Style x:Key="FC" TargetType="ComboBox">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="Background"      Value="#313244"/>
            <Setter Property="BorderBrush"     Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,0,6,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- 主体边框 -->
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 当前值显示 -->
                                    <ContentPresenter Grid.Column="0"
                                                      x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      IsHitTestVisible="False"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"/>
                                    <!-- 下拉箭头按钮 -->
                                    <Border Grid.Column="1"
                                            x:Name="ArrowBd"
                                            Background="Transparent">
                                        <TextBlock Text="&#x2304;"
                                                   FontSize="14"
                                                   Foreground="#6C7086"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-2,0,0"/>
                                    </Border>
                                    <!-- 用于捕获点击的透明按钮 -->
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Cursor="Hand"/>
                                </Grid>
                            </Border>
                            <!-- 下拉弹出层 -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=Bd}"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropBd"
                                        MinWidth="{Binding ActualWidth, ElementName=Bd}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#252535"
                                        BorderBrush="#45475A"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="4,4">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="4"
                                                          Opacity="0.45" Color="#000000"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- 获得焦点时蓝色边框 -->
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <!-- 鼠标悬停 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6C7086"/>
                            </Trigger>
                            <!-- 展开时蓝色边框 -->
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 可编辑分组下拉框：允许输入新分组名，也可从现有分组中选择 -->
        <Style x:Key="FIC" TargetType="ComboBox">
            <Setter Property="Background"               Value="#313244"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#45475A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="IsEditable"               Value="True"/>
            <Setter Property="IsTextSearchEnabled"      Value="True"/>
            <Setter Property="SnapsToDevicePixels"      Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Grid.Column="0"
                                             Margin="10,0,0,0"
                                             VerticalAlignment="Center"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#CDD6F4"
                                             CaretBrush="#89B4FA"
                                             SelectionBrush="#89B4FA"
                                             Focusable="True"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"/>
                                    <Border Grid.Column="1" Background="Transparent">
                                        <TextBlock Text="&#x2304;" FontSize="14"
                                                   Foreground="#6C7086"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-2,0,0"/>
                                    </Border>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  HorizontalAlignment="Right"
                                                  Width="28" Focusable="False"
                                                  Background="Transparent" BorderThickness="0"
                                                  Cursor="Hand"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=Bd}"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, ElementName=Bd}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#252535"
                                        BorderBrush="#45475A"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="4,4">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="4"
                                                          Opacity="0.45" Color="#000000"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 下拉选项样式 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#3D3F58"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1A3254"/>
                                <Setter Property="Foreground" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- 整体使用 StackPanel，自动适应内容高度，无滚动条 -->
    <StackPanel Margin="28,22,28,24">

        <!-- ── 连接信息 ── -->
        <DockPanel Margin="0,0,0,14">
            <Border DockPanel.Dock="Left"
                    Width="3" CornerRadius="2"
                    Background="#89B4FA"
                    Margin="0,1,10,1"/>
            <TextBlock Text="连接信息"
                       Foreground="#89B4FA"
                       FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- 名称 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="名称 *" Style="{StaticResource FL}"/>
            <TextBox   x:Name="NameBox" Grid.Column="1"
                       Style="{StaticResource FI}" KeyDown="InputBox_KeyDown"/>
        </Grid>

        <!-- IP 地址 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="IP 地址 *" Style="{StaticResource FL}"/>
            <TextBox   x:Name="IpBox" Grid.Column="1"
                       Style="{StaticResource FI}" KeyDown="InputBox_KeyDown"/>
        </Grid>

        <!-- 协议 + 端口（同行） -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="协议" Style="{StaticResource FL}"/>
            <ComboBox  x:Name="ProtocolBox" Grid.Column="1"
                       Style="{StaticResource FC}"
                       SelectionChanged="ProtocolBox_SelectionChanged">
                <ComboBoxItem Content="RDP"    Tag="RDP"/>
                <ComboBoxItem Content="SSH"    Tag="SSH"/>
                <ComboBoxItem Content="Telnet" Tag="Telnet"/>
            </ComboBox>
            <TextBlock Grid.Column="3" Text="端口"
                       Style="{StaticResource FL}" HorizontalAlignment="Right"/>
            <TextBox   x:Name="PortBox" Grid.Column="4"
                       Style="{StaticResource FI}" KeyDown="InputBox_KeyDown"/>
        </Grid>

        <!-- 分组 -->
        <Grid Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="分组" Style="{StaticResource FL}"/>
            <ComboBox  x:Name="GroupBox" Grid.Column="1"
                       Style="{StaticResource FIC}"
                       ToolTip="可选，选择现有分组或直接输入新分组名"/>
        </Grid>

        <!-- 通过 SOCKS 连接（多机房选择代理） -->
        <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="连接方式" Style="{StaticResource FL}" VerticalAlignment="Center"/>
            <ComboBox x:Name="SocksProxyCombo" Grid.Column="1" Style="{StaticResource FC}"
                      ToolTip="直连或通过某机房的 SOCKS 跳板机连接"/>
        </Grid>

        <!-- ── 认证 ── -->
        <DockPanel Margin="0,22,0,14">
            <Border DockPanel.Dock="Left"
                    Width="3" CornerRadius="2"
                    Background="#89B4FA"
                    Margin="0,1,10,1"/>
            <TextBlock Text="认证"
                       Foreground="#89B4FA"
                       FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- 用户名 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="用户名" Style="{StaticResource FL}"/>
            <TextBox   x:Name="UsernameBox" Grid.Column="1"
                       Style="{StaticResource FI}" KeyDown="InputBox_KeyDown"/>
        </Grid>

        <!-- 密码 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="PasswordLabel" Grid.Column="0" Text="密码" Style="{StaticResource FL}"
                       ToolTip="SSH 私钥认证时，此处填写私钥口令（passphrase）；无口令则留空"/>
            <PasswordBox x:Name="PasswordBox" Grid.Column="1"
                         Style="{StaticResource FP}" KeyDown="InputBox_KeyDown"
                         GotKeyboardFocus="PasswordBox_GotFocus"/>
        </Grid>

        <!-- SSH 私钥路径（仅 SSH 协议可见） -->
        <Grid x:Name="SshKeyRow" Margin="0,0,0,0" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="私钥文件" Style="{StaticResource FL}"
                       ToolTip="SSH 私钥文件（.pem / .ppk / OpenSSH），留空则使用密码验证"/>
            <TextBox   x:Name="SshKeyBox" Grid.Column="1"
                       Style="{StaticResource FI}"
                       ToolTip="SSH 私钥文件路径（留空使用密码验证）"
                       KeyDown="InputBox_KeyDown"/>
            <Button    Grid.Column="3"
                       Content="浏览..."
                       Height="34" FontSize="12"
                       Style="{StaticResource DlgSecondaryBtn}"
                       Click="BrowseSshKey_Click"/>
        </Grid>

        <!-- ── 备注 ── -->
        <DockPanel Margin="0,22,0,14">
            <Border DockPanel.Dock="Left"
                    Width="3" CornerRadius="2"
                    Background="#89B4FA"
                    Margin="0,1,10,1"/>
            <TextBlock Text="备注"
                       Foreground="#89B4FA"
                       FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- 描述多行输入 -->
        <TextBox x:Name="DescriptionBox"
                 Background="#313244"
                 Foreground="#CDD6F4"
                 BorderBrush="#45475A"
                 BorderThickness="1"
                 CaretBrush="#89B4FA"
                 SelectionBrush="#89B4FA"
                 Padding="10,8"
                 FontSize="12"
                 Height="80"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Top">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="#89B4FA"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <!-- ── 按钮栏 ── -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,22,0,0">
            <Button Content="取 消"
                    Width="96" Height="34"
                    Margin="0,0,10,0"
                    Style="{StaticResource DlgSecondaryBtn}"
                    Click="CancelButton_Click"
                    IsCancel="True"/>
            <Button Content="确 定"
                    Width="96" Height="34"
                    Style="{StaticResource DlgPrimaryBtn}"
                    Click="OkButton_Click"
                    IsDefault="True"/>
        </StackPanel>

    </StackPanel>
</Window>
