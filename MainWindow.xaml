<Window x:Class="RemoteX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="RemoteX"
        MinWidth="900" MinHeight="600"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <Window.Resources>

        <!-- ── Catppuccin Mocha palette ── -->
        <SolidColorBrush x:Key="Bg"       Color="#1E1E2E"/>
        <SolidColorBrush x:Key="Mantle"   Color="#181825"/>
        <SolidColorBrush x:Key="Crust"    Color="#11111B"/>
        <SolidColorBrush x:Key="Surface0" Color="#313244"/>
        <SolidColorBrush x:Key="Surface1" Color="#45475A"/>
        <SolidColorBrush x:Key="Overlay0" Color="#6C7086"/>
        <SolidColorBrush x:Key="Text"     Color="#CDD6F4"/>
        <SolidColorBrush x:Key="Subtext"  Color="#A6ADC8"/>
        <SolidColorBrush x:Key="Blue"     Color="#89B4FA"/>
        <SolidColorBrush x:Key="Green"    Color="#A6E3A1"/>

        <!-- ── Slim vertical scrollbar ── -->
        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Bd" Background="#45475A" CornerRadius="3" Margin="2,1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6C7086"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollPageBtnStyle" TargetType="RepeatButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="6" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollPageBtnStyle}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollPageBtnStyle}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Flat button: neutral ── -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Flat button: green (add) ── -->
        <Style x:Key="FlatBtnGreen" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A6E3A1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1B2D1B"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#253D25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Flat button: red (delete / disconnect) ── -->
        <Style x:Key="FlatBtnDanger" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F38BA8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D1B25"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D2030"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ListBox: transparent, no border ── -->
        <Style x:Key="ServerListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer Padding="{TemplateBinding Padding}"
                                      Focusable="False"
                                      Background="Transparent">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ListBoxItem: rounded hover / selection ── -->
        <Style x:Key="ServerItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="7" Padding="10,8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3254"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 分组头样式 ── -->
        <Style x:Key="GroupHeaderStyle" TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <StackPanel>
                            <!-- 分组标题 -->
                            <Border Padding="14,5,8,3" Margin="0,4,0,0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="{Binding Name}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#6C7086"
                                               VerticalAlignment="Center"/>
                                    <Border DockPanel.Dock="Left"
                                            Height="1"
                                            Background="#313244"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <!-- 分组内容 -->
                            <ItemsPresenter/>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Window.Background>
        <ImageBrush ImageSource="/background.png"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="268" MinWidth="0" MaxWidth="500"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════ SIDEBAR ════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource Mantle}"
                BorderBrush="{StaticResource Surface0}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1: search + buttons -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2: 最近连接 -->
                    <RowDefinition Height="1"/>
                    <!-- 3: divider -->
                    <RowDefinition Height="*"/>
                    <!-- 4: server list -->
                    <RowDefinition Height="Auto"/>
                    <!-- 5: footer -->
                </Grid.RowDefinitions>

                <!-- APP HEADER -->
                <Border Grid.Row="0" Background="{StaticResource Crust}" Padding="14,14">
                    <DockPanel>
                        <Border DockPanel.Dock="Left"
                                Width="38" Height="38"
                                CornerRadius="10"
                                Margin="0,0,11,0">
                            <Border.Background>
                                <ImageBrush ImageSource="/background.png" TileMode="None" Stretch="Fill"/>
                            </Border.Background>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="RemoteX"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource Text}"/>
                            <TextBlock Text="多协议远程管理"
                                       FontSize="10"
                                       Foreground="{StaticResource Overlay0}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- SEARCH + ACTION BUTTONS -->
                <StackPanel Grid.Row="1" Margin="10,10,10,10">

                    <!-- Search box -->
                    <Border Background="{StaticResource Surface0}"
                            CornerRadius="7" Height="34" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#x2315;"
                                       FontSize="17"
                                       Foreground="{StaticResource Overlay0}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="SearchBox"
                                         Background="Transparent"
                                         Foreground="{StaticResource Text}"
                                         BorderThickness="0"
                                         Padding="0,0,8,0"
                                         VerticalContentAlignment="Center"
                                         CaretBrush="{StaticResource Blue}"
                                         SelectionBrush="{StaticResource Blue}"
                                         FontSize="12"
                                         TextChanged="SearchBox_TextChanged"/>
                                <TextBlock Text="搜索服务器..."
                                           FontSize="12"
                                           Foreground="{StaticResource Overlay0}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=SearchBox, Path=Text}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Action buttons row 1: CRUD + Health -->
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="AddServerButton"
                                Style="{StaticResource FlatBtnGreen}"
                                Click="AddServerButton_Click"
                                ToolTip="新增服务器 (Ctrl+N)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="15" FontWeight="Bold"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="新增" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="EditServerButton"
                                Style="{StaticResource FlatBtn}"
                                Click="EditServerButton_Click"
                                ToolTip="编辑选中服务器"
                                Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x270E;" FontSize="13"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="编辑" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="DeleteServerButton"
                                Style="{StaticResource FlatBtnDanger}"
                                Click="DeleteServerButton_Click"
                                ToolTip="删除选中服务器 (Delete)">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2715;" FontSize="12"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="删除" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="CheckAllButton"
                                Style="{StaticResource FlatBtn}"
                                Click="CheckAllButton_Click"
                                ToolTip="检测全部服务器端口 (F5)"
                                Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2299;" FontSize="12"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="检测" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Action buttons row 2: Import / Export / Settings -->
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Button x:Name="ImportButton"
                                Style="{StaticResource FlatBtn}"
                                Click="ImportButton_Click"
                                ToolTip="从备份文件批量导入服务器">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2193;" FontSize="14" FontWeight="Bold"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="导入" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ExportButton"
                                Style="{StaticResource FlatBtn}"
                                Click="ExportButton_Click"
                                ToolTip="将服务器列表导出为备份文件"
                                Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2191;" FontSize="14" FontWeight="Bold"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="导出" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource FlatBtn}"
                                Click="SettingsButton_Click"
                                ToolTip="打开设置 (Ctrl+,)"
                                Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2699;" FontSize="13"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="设置" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ProxyButton"
                                Style="{StaticResource FlatBtn}"
                                Click="ProxyButton_Click"
                                ToolTip="管理 SOCKS5 代理（跳板机）"
                                Margin="4,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F517;" FontSize="12"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="代理" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- 最近连接面板 -->
                <Border x:Name="RecentSection"
                        Grid.Row="2"
                        Background="{StaticResource Crust}"
                        BorderBrush="{StaticResource Surface0}"
                        BorderThickness="0,0,0,1"
                        Visibility="Collapsed">
                    <StackPanel Margin="10,6,10,6">
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="最近连接"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource Overlay0}"
                                       VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right"
                                    x:Name="ClearRecentButton"
                                    Style="{StaticResource FlatBtn}"
                                    Click="ClearRecentButton_Click"
                                    ToolTip="清除最近连接记录"
                                    Padding="4,1"
                                    FontSize="10">
                                <TextBlock Text="清除" Foreground="{StaticResource Overlay0}"/>
                            </Button>
                        </DockPanel>
                        <StackPanel x:Name="RecentList" Orientation="Vertical"/>
                    </StackPanel>
                </Border>

                <!-- DIVIDER -->
                <Border Grid.Row="3" Background="{StaticResource Surface0}"/>

                <!-- SERVER LIST（支持拖拽排序） -->
                <ListBox x:Name="ServerList"
                         Grid.Row="4"
                         Style="{StaticResource ServerListStyle}"
                         ItemContainerStyle="{StaticResource ServerItemStyle}"
                         SelectionChanged="ServerList_SelectionChanged"
                         PreviewMouseRightButtonDown="ServerList_PreviewMouseRightButtonDown"
                         PreviewMouseLeftButtonDown="ServerList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="ServerList_PreviewMouseMove"
                         MouseDoubleClick="ServerList_MouseDoubleClick"
                         Drop="ServerList_Drop"
                         DragOver="ServerList_DragOver"
                         AllowDrop="True"
                         ScrollViewer.CanContentScroll="False"
                         VirtualizingPanel.IsVirtualizingWhenGrouping="False">

                    <!-- 右键菜单 -->
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="&#x1F4BB;  连接 (Enter)"
                                      Foreground="#A6E3A1"
                                      Click="MenuConnect_Click"/>
                            <MenuItem Header="&#x1F50E;  检测端口"
                                      Click="MenuCheck_Click"/>
                            <MenuItem Header="&#x2715; 断开"
                                      Click="MenuDisconnect_Click"/>
                            <Separator/>
                            <MenuItem Header="&#x1F4CB;  复制 IP"
                                      Click="MenuCopyIp_Click"/>
                            <MenuItem Header="&#x1F4CB;  复制地址"
                                      Click="MenuCopyAddress_Click"/>
                            <Separator/>
                            <MenuItem Header="&#x270E; 编辑"
                                      Click="MenuEdit_Click"/>
                            <MenuItem Header="&#x1F4CB; 克隆 (Ctrl+D)"
                                      Click="MenuClone_Click"/>
                            <MenuItem Header="&#x2715; 删除 (Del)"
                                      Foreground="#F38BA8"
                                      Click="MenuDelete_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>

                    <!-- 分组样式 -->
                    <ListBox.GroupStyle>
                        <GroupStyle ContainerStyle="{StaticResource GroupHeaderStyle}"/>
                    </ListBox.GroupStyle>

                    <!-- 数据模板 -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- 第一行：服务器名 + 健康状态 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding HealthBadge}"
                                               FontSize="10"
                                               Margin="8,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Overlay0}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HealthState}" Value="Online">
                                                        <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HealthState}" Value="Checking">
                                                        <Setter Property="Foreground" Value="{StaticResource Blue}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HealthState}" Value="Offline">
                                                        <Setter Property="Foreground" Value="#F38BA8"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <!-- 第二行：协议徽章 + 地址 -->
                                <DockPanel Margin="0,3,0,0">
                                    <!-- 协议徽章 -->
                                    <Border DockPanel.Dock="Left"
                                            CornerRadius="3" Padding="4,1"
                                            Margin="0,0,6,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#3B4252"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Protocol}" Value="SSH">
                                                        <Setter Property="Background" Value="#1E3A2F"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Protocol}" Value="Telnet">
                                                        <Setter Property="Background" Value="#2D2B1E"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding ProtocolBadge}"
                                                   FontSize="9" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#89B4FA"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Protocol}" Value="SSH">
                                                            <Setter Property="Foreground" Value="#A6E3A1"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Protocol}" Value="Telnet">
                                                            <Setter Property="Foreground" Value="#F9E2AF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <!-- 地址 -->
                                    <TextBlock Text="{Binding AddressDisplay}"
                                               FontSize="11"
                                               Foreground="{StaticResource Overlay0}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- FOOTER -->
                <Border Grid.Row="5"
                        Background="{StaticResource Crust}"
                        BorderBrush="{StaticResource Surface0}"
                        BorderThickness="0,1,0,0"
                        Padding="14,8">
                    <TextBlock x:Name="ServerCountText"
                               FontSize="11"
                               Foreground="{StaticResource Overlay0}"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ════════════════ MAIN AREA ════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ToolbarRow" Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="StatusBarRow" Height="34"/>
            </Grid.RowDefinitions>

            <!-- TOOLBAR -->
            <Border Grid.Row="0"
                    Background="{StaticResource Crust}"
                    BorderBrush="{StaticResource Surface0}"
                    BorderThickness="0,0,0,1">
                <DockPanel Margin="10,0" VerticalAlignment="Center">
                    <Button x:Name="ToggleSidebarButton"
                            DockPanel.Dock="Left"
                            Style="{StaticResource FlatBtn}"
                            Click="ToggleSidebarButton_Click"
                            ToolTip="收起侧边栏"
                            Margin="0,0,4,0">
                        <TextBlock x:Name="ToggleSidebarIcon"
                                   Text="&#x25C0;"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="DisconnectButton"
                            DockPanel.Dock="Left"
                            Style="{StaticResource FlatBtnDanger}"
                            Click="DisconnectButton_Click"
                            ToolTip="断开当前连接 (Ctrl+W)"
                            Visibility="Collapsed"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2715;" FontSize="13"
                                       Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="断开连接" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Border DockPanel.Dock="Left"
                            Width="1"
                            Background="{StaticResource Surface1}"
                            Margin="6,10"/>
                    <TextBlock x:Name="StatusText"
                               DockPanel.Dock="Left"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Overlay0}"
                               FontSize="12"
                               Text="未连接"/>
                </DockPanel>
            </Border>

            <!-- RDP 嵌入区 -->
            <Grid Grid.Row="1" Background="{StaticResource Bg}">
                <Grid x:Name="RdpContainer"
                      Visibility="Collapsed"
                      Background="{StaticResource Bg}"/>

                <!-- SSH / Telnet 终端 WebView2 -->
                <wv2:WebView2 x:Name="TerminalWebView"
                              Visibility="Collapsed"/>

                <!-- 空闲面板：最近连接卡片 + 快捷键提示 -->
                <Grid x:Name="IdlePanel">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,32">
                        <StackPanel MaxWidth="680">
                            <!-- 品牌标志区 -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,36">
                                <Border Width="64" Height="64"
                                        CornerRadius="18"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,14">
                                    <Border.Background>
                                        <ImageBrush ImageSource="/background.png" TileMode="None" Stretch="Fill"/>
                                    </Border.Background>
                                </Border>
                                <TextBlock Text="RemoteX"
                                           FontSize="22" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="选择左侧服务器，双击或按 Enter 建立连接"
                                           FontSize="13"
                                           Foreground="{StaticResource Overlay0}"
                                           HorizontalAlignment="Center"
                                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <!-- 最近连接标题 -->
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="最近连接"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource Overlay0}"
                                           VerticalAlignment="Center"/>
                                <Border Height="1"
                                        Background="{StaticResource Surface0}"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- 最近连接卡片列表（由代码填充） -->
                            <ItemsControl x:Name="RecentCardsPanel">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <!-- 无历史提示（默认显示，有卡片后隐藏） -->
                            <TextBlock x:Name="NoRecentHint"
                                       Text="暂无最近连接记录"
                                       FontSize="13"
                                       Foreground="{StaticResource Surface1}"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>

                            <!-- 快捷键提示 -->
                            <Border Background="{StaticResource Surface0}"
                                    CornerRadius="8"
                                    Padding="20,14"
                                    Margin="0,32,0,0">
                                <UniformGrid Columns="3" Rows="2">
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="Ctrl+N" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Blue}"/>
                                        <TextBlock Text="新增服务器" FontSize="11" Foreground="{StaticResource Overlay0}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="Enter / 双击" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Blue}"/>
                                        <TextBlock Text="连接服务器" FontSize="11" Foreground="{StaticResource Overlay0}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="F5" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Blue}"/>
                                        <TextBlock Text="检测所有端口" FontSize="11" Foreground="{StaticResource Overlay0}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Delete" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Blue}"/>
                                        <TextBlock Text="删除服务器" FontSize="11" Foreground="{StaticResource Overlay0}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Ctrl+W" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Blue}"/>
                                        <TextBlock Text="关闭当前标签" FontSize="11" Foreground="{StaticResource Overlay0}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Ctrl+," FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Blue}"/>
                                        <TextBlock Text="打开设置" FontSize="11" Foreground="{StaticResource Overlay0}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </UniformGrid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- STATUS BAR -->
            <Border Grid.Row="2"
                    Background="{StaticResource Crust}"
                    BorderBrush="{StaticResource Surface0}"
                    BorderThickness="0,1,0,0">
                <DockPanel Margin="8,0" LastChildFill="True">

                    <TextBlock x:Name="AppVersionText"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Surface1}"
                               FontSize="11"
                               Margin="0,0,4,0"/>

                    <ScrollViewer DockPanel.Dock="Left"
                                  x:Name="RdpTabScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Hidden"
                                  MaxWidth="560"
                                  Visibility="Collapsed">
                        <StackPanel x:Name="RdpTabStrip"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"/>
                    </ScrollViewer>

                    <Border DockPanel.Dock="Left"
                            x:Name="RdpTabSeparator"
                            Width="1"
                            Background="{StaticResource Surface0}"
                            Margin="4,8"
                            Visibility="Collapsed"/>

                    <TextBlock x:Name="DescriptionText"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource Overlay0}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="8,0,0,0"/>
                </DockPanel>
            </Border>

            <!-- Toast 通知（右下角浮动，非阻塞） -->
            <Border x:Name="ToastPanel"
                    Grid.RowSpan="3"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="16,0,16,60"
                    Padding="14,10"
                    CornerRadius="6"
                    Background="#313244"
                    BorderBrush="#45475A"
                    BorderThickness="1"
                    Visibility="Collapsed">
                <TextBlock x:Name="ToastText" Foreground="#CDD6F4" FontSize="12" TextWrapping="Wrap" MaxWidth="280"/>
            </Border>
        </Grid>
    </Grid>
</Window>
