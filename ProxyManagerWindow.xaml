<Window x:Class="RemoteX.ProxyManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="代理管理"
        Width="560"
        SizeToContent="Height"
        MaxHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        Loaded="Window_Loaded">

    <Window.Resources>

        <Style x:Key="RL" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#CDD6F4"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RH" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#6C7086"/>
            <Setter Property="FontSize"     Value="10.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TI" TargetType="TextBox">
            <Setter Property="Background"               Value="#313244"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#45475A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="CaretBrush"               Value="#89B4FA"/>
            <Setter Property="SelectionBrush"           Value="#89B4FA"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <EventSetter Event="GotKeyboardFocus" Handler="Input_GotFocus"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#89B4FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 密码框：ControlTemplate 强制垂直居中 -->
        <Style x:Key="PI" TargetType="PasswordBox">
            <Setter Property="Background"               Value="#313244"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#45475A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="CaretBrush"               Value="#89B4FA"/>
            <Setter Property="SelectionBrush"           Value="#89B4FA"/>
            <Setter Property="Padding"                  Value="8,0"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Hidden"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <StackPanel Margin="24,20,24,24">

        <!-- 标题栏 -->
        <DockPanel Margin="0,0,0,16">
            <Border DockPanel.Dock="Left" Width="3" CornerRadius="2"
                    Background="#F9E2AF" Margin="0,1,10,1"/>
            <TextBlock Text="SOCKS5 代理管理"
                       Foreground="#F9E2AF"
                       FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <TextBlock Style="{StaticResource RH}"
                   Margin="0,0,0,14"
                   Text="每机房配置一个代理；在「编辑服务器」中选择该服务器通过哪个代理连接。"/>

        <!-- 列表 + 操作按钮 -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ProxyListBox"
                     Grid.Column="0"
                     MinHeight="100" MaxHeight="180"
                     Background="#313244" Foreground="#CDD6F4"
                     BorderBrush="#45475A" BorderThickness="1"
                     FontSize="12" Padding="6,4"
                     DisplayMemberPath="DisplayName"
                     SelectionChanged="ProxyListBox_SelectionChanged"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,0,0">
                <Button Content="添加" Height="32" Margin="0,0,0,6"
                        Style="{StaticResource DlgSecondaryBtn}"
                        Click="AddProxy_Click"/>
                <Button Content="更新" Height="32" Margin="0,0,0,6"
                        Style="{StaticResource DlgSecondaryBtn}"
                        Click="SaveProxy_Click"/>
                <Button Content="删除" Height="32"
                        Style="{StaticResource DlgSecondaryBtn}"
                        Click="DeleteProxy_Click"/>
            </StackPanel>
        </Grid>

        <!-- 编辑表单 -->
        <Border Background="#252536" CornerRadius="8" Padding="16,14" Margin="0,0,0,0">
            <StackPanel>
                <TextBlock Text="选中列表项后在此编辑，完成后点击「更新」保存"
                           Style="{StaticResource RH}" Margin="0,0,0,12"/>

                <!-- 名称 + 主机 + 端口 -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="72"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="名称" Style="{StaticResource RL}"/>
                    <TextBox   Grid.Column="1" x:Name="NameBox" Style="{StaticResource TI}"/>
                    <TextBlock Grid.Column="3" Text="主机" Style="{StaticResource RL}"/>
                    <TextBox   Grid.Column="4" x:Name="HostBox" Style="{StaticResource TI}"/>
                    <TextBlock Grid.Column="6" Text="端口" Style="{StaticResource RL}"/>
                    <TextBox   Grid.Column="7" x:Name="PortBox" Style="{StaticResource TI}"
                               Text="1080"/>
                </Grid>

                <!-- 用户名 + 密码 -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="用户名" Style="{StaticResource RL}"/>
                    <TextBox   Grid.Column="1" x:Name="UsernameBox" Style="{StaticResource TI}"/>
                    <TextBlock Grid.Column="3" Text="密码" Style="{StaticResource RL}"/>
                    <PasswordBox Grid.Column="4" x:Name="PasswordBox" Style="{StaticResource PI}"
                                 GotKeyboardFocus="PasswordBox_GotFocus"/>
                </Grid>

                <!-- TLS 配置 -->
                <StackPanel>
                    <CheckBox x:Name="UseTlsBox"
                              Content="通过 TLS 连接代理服务端"
                              Foreground="#CDD6F4"
                              Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="证书名称" Style="{StaticResource RL}"/>
                        <TextBox Grid.Column="1" x:Name="TlsServerNameBox" Style="{StaticResource TI}"
                                 ToolTip="可选。用于 TLS 主机名校验 / SNI，留空时默认使用代理主机地址"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SHA256" Style="{StaticResource RL}"/>
                        <TextBox Grid.Column="1" x:Name="TlsPinnedSha256Box" Style="{StaticResource TI}"
                                 ToolTip="可选。填写服务端证书 SHA256 指纹后，将按指纹固定证书"/>
                    </Grid>
                    <TextBlock Style="{StaticResource RH}" Margin="0,8,0,0"
                               Text="启用 TLS 后，默认会校验证书；若使用自签证书，可填写 SHA256 指纹进行固定。"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 按钮栏 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="关 闭"
                    Width="96" Height="34"
                    Style="{StaticResource DlgPrimaryBtn}"
                    Click="CloseButton_Click"
                    IsDefault="True" IsCancel="True"/>
        </StackPanel>

    </StackPanel>
</Window>
