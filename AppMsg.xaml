<Window x:Class="RemoteX.AppMsg"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        MinWidth="360" MaxWidth="520"
        Background="#11111B"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#1E1E2E"
            BorderBrush="#45475A"
            BorderThickness="1">
        <StackPanel>

            <!-- 标题栏 -->
            <Border Background="#181825"
                    Padding="16,10"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TitleText"
                               Grid.Column="0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#CDD6F4"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="✕"
                            FontSize="12"
                            Width="24" Height="24"
                            Padding="0"
                            Foreground="#6C7086"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="CloseBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                    Background="Transparent"
                                                    CornerRadius="4"
                                                    Width="24" Height="24">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                    <Setter Property="Foreground" Value="#F38BA8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <Grid Margin="24,20,24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 图标 -->
                <TextBlock x:Name="IconText"
                           Grid.Column="0"
                           FontSize="28"
                           VerticalAlignment="Top"
                           Margin="0,2,16,0"/>

                <!-- 消息文字 -->
                <TextBlock x:Name="MessageText"
                           Grid.Column="1"
                           FontSize="13"
                           Foreground="#CDD6F4"
                           TextWrapping="Wrap"
                           LineHeight="20"
                           VerticalAlignment="Center"
                           MaxWidth="380"/>
            </Grid>

            <!-- 分割线 -->
            <Border Height="1" Background="#313244" Margin="0"/>

            <!-- 按钮区 -->
            <StackPanel x:Name="ButtonPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="16,14,16,14">

                <Button x:Name="CancelBtn"
                        Visibility="Collapsed"
                        MinWidth="80"
                        Height="32"
                        Padding="16,0"
                        Margin="0,0,8,0"
                        Cursor="Hand"
                        Click="CancelBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                BorderBrush="#45475A"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6C7086"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock x:Name="CancelText"
                               FontSize="12"
                               Foreground="#A6ADC8"/>
                </Button>

                <Button x:Name="ConfirmBtn"
                        MinWidth="80"
                        Height="32"
                        Padding="16,0"
                        Cursor="Hand"
                        IsDefault="True"
                        Click="ConfirmBtn_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Tag}"
                                                CornerRadius="5"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock x:Name="ConfirmText"
                               FontSize="12"
                               Foreground="#1E1E2E"
                               FontWeight="SemiBold"/>
                </Button>

            </StackPanel>
        </StackPanel>
    </Border>
</Window>
