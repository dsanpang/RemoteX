<Window x:Class="RemoteX.PortForwardEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        SizeToContent="Height"
        MaxHeight="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        Loaded="Window_Loaded">

    <Window.Resources>

        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground"          Value="#A6ADC8"/>
            <Setter Property="FontSize"            Value="12"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin"              Value="0,0,14,0"/>
        </Style>

        <Style x:Key="FI" TargetType="TextBox">
            <Setter Property="Background"               Value="#313244"/>
            <Setter Property="Foreground"               Value="#CDD6F4"/>
            <Setter Property="BorderBrush"              Value="#45475A"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="CaretBrush"               Value="#89B4FA"/>
            <Setter Property="SelectionBrush"           Value="#89B4FA"/>
            <Setter Property="Padding"                  Value="10,0"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#89B4FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FC" TargetType="ComboBox">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="Background"      Value="#313244"/>
            <Setter Property="BorderBrush"     Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,0,6,0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="28"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      x:Name="ContentSite"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      IsHitTestVisible="False"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="Transparent">
                                        <TextBlock Text="&#x2304;" FontSize="14"
                                                   Foreground="#6C7086"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-2,0,0"/>
                                    </Border>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=Bd}"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, ElementName=Bd}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#252535"
                                        BorderBrush="#45475A"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="4,4">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.45" Color="#000000"/>
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground"  Value="#CDD6F4"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Padding"     Value="10,6"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#3D3F58"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#1A3254"/>
                                <Setter Property="Foreground" Value="#89B4FA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgPrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="#89B4FA"/>
            <Setter Property="Foreground"   Value="#1E1E2E"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#74A0E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5E8ED6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgSecondaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="#313244"/>
            <Setter Property="Foreground"   Value="#CDD6F4"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"  Value="#45475A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D3F58"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <StackPanel Margin="28,22,28,24">

        <!-- 标题栏 -->
        <DockPanel Margin="0,0,0,18">
            <Border DockPanel.Dock="Left" Width="3" CornerRadius="2"
                    Background="#89B4FA" Margin="0,1,10,1"/>
            <TextBlock x:Name="TitleLabel" Text="新增转发规则"
                       Foreground="#89B4FA" FontSize="11" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- 规则名称 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="规则名称 *" Style="{StaticResource FL}"/>
            <TextBox x:Name="NameBox" Grid.Column="1" Style="{StaticResource FI}"
                     KeyDown="InputBox_KeyDown"/>
        </Grid>

        <!-- 关联服务器 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="SSH 服务器 *" Style="{StaticResource FL}"/>
            <ComboBox x:Name="ServerCombo" Grid.Column="1" Style="{StaticResource FC}"
                      DisplayMemberPath="Name"/>
        </Grid>

        <!-- 转发类型 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="转发类型" Style="{StaticResource FL}"/>
            <ComboBox x:Name="TypeCombo" Grid.Column="1" Style="{StaticResource FC}"
                      SelectionChanged="TypeCombo_SelectionChanged">
                <ComboBoxItem Content="本地转发 (Local)"   Tag="Local"/>
                <ComboBoxItem Content="远程转发 (Remote)"  Tag="Remote"/>
                <ComboBoxItem Content="动态 SOCKS 代理"    Tag="Dynamic"/>
            </ComboBox>
        </Grid>

        <!-- 本地端口 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="本地端口 *" Style="{StaticResource FL}"/>
            <TextBox x:Name="LocalPortBox" Grid.Column="1" Style="{StaticResource FI}"
                     KeyDown="InputBox_KeyDown"/>
        </Grid>

        <!-- 远端主机（Dynamic 时隐藏） -->
        <Grid x:Name="RemoteHostRow" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="远端主机" Style="{StaticResource FL}"/>
            <TextBox x:Name="RemoteHostBox" Grid.Column="1" Style="{StaticResource FI}"
                     KeyDown="InputBox_KeyDown"/>
        </Grid>

        <!-- 远端端口（Dynamic 时隐藏） -->
        <Grid x:Name="RemotePortRow" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="远端端口 *" Style="{StaticResource FL}"/>
            <TextBox x:Name="RemotePortBox" Grid.Column="1" Style="{StaticResource FI}"
                     KeyDown="InputBox_KeyDown"/>
        </Grid>

        <!-- 自动启动 -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="自动启动" Style="{StaticResource FL}"/>
            <CheckBox x:Name="AutoStartCheck" Grid.Column="1"
                      Foreground="#CDD6F4" FontSize="12"
                      Content="窗口启动时自动开启转发"
                      VerticalAlignment="Center"/>
        </Grid>

        <!-- 按钮栏 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取 消" Width="96" Height="34" Margin="0,0,10,0"
                    Style="{StaticResource DlgSecondaryBtn}"
                    Click="CancelButton_Click" IsCancel="True"/>
            <Button Content="确 定" Width="96" Height="34"
                    Style="{StaticResource DlgPrimaryBtn}"
                    Click="OkButton_Click" IsDefault="True"/>
        </StackPanel>

    </StackPanel>
</Window>
